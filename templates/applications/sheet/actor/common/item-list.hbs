{{#if items.length }}
  <div>
    <h2 class="text-large">{{title}}</h2>
    <div class="grid">
      <div class="col gap-2">
        {{#each items as |item|}}
          <div class="grid item draggable" data-item-id="{{item._id}}" data-source="{{item.name}}">
            <div class="col col-9 pr-2">
              <div class="text-regular text-bold">
                {{item.name}}
                <span class="text-regular">
                  {{#if item.system.quantity}}
                    ({{item.system.quantity.value}}{{#if item.system.quantity.max}}/{{item.system.quantity.max}}{{/if}})
                  {{/if}}
                </span>
              </div>
              <div class="item-description">
                {{> (concat (lookup item 'type') '-description') item=item }}
              </div>
            </div>
            <div class="col col-3">
              <div class="grid justify-content-end gap-1">
                {{#if (eq item.type 'misc')}}
                  {{#if item.system.quantity}}
                    <a data-action="itemIncreaseQuantity" class="item-action" title="Add Quantity">
                      <i class="fas fa-plus"></i>
                    </a>
                    <a data-action="itemDecreaseQuantity" class="item-action" title="Subtract Quantity">
                      <i class="fas fa-minus"></i>
                    </a>
                  {{/if}}
                {{/if}}
                {{#if item.extra.isEquippable}}
                  <a data-action="itemToggleEquipped" class="item-action {{printIf item.system.equipped 'equipped'}}" title="{{printIfElse item.system.equipped (localize 'MB.Item.Unequip') (localize 'MB.Item.Equip')}}">
                    <i class="fas fa-fist-raised {{printIf item.system.equipped 'highlight'}}"></i>
                  </a>
                {{/if}}
                <a data-action="itemEdit" class="item-action" title="{{localize 'MB.Item.Edit'}}"> <i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" class="item-action" title="{{localize 'MB.Item.Delete'}}"> <i class="fas fa-trash"></i></a>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    </div>
  </div>
{{/if}}

{{#*inline "ability-description"}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "passion-description"}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "misc-description"}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "scar-description"}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "plate-description"}}
  {{#if item.system.armor}}
    <p>A{{item.system.armor}}</p>
  {{/if}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "coat-description"}}
  {{#if item.system.armor}}
    <p>A{{item.system.armor}}</p>
  {{/if}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "helm-description"}}
  {{#if item.system.armor}}
    <p>A{{item.system.armor}}</p>
  {{/if}}
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "shield-description"}}
  <p>
    A{{item.system.armor}},
    <a data-action="inlineRoll" class="inline-roll roll" data-mode="roll" data-flavor="damage" data-formula="{{item.system.damage}}"><i class="fas fa-dice-d20"></i>{{item.system.damage}}</a>
  </p>
  {{{item.extra.enrichedDescription}}}
{{/inline}}

{{#*inline "weapon-description"}}
  <p>
    <a data-action="inlineRoll" class="inline-roll roll" data-mode="roll" data-flavor="damage" data-formula="{{item.system.damage}}"><i class="fas fa-dice-d20"></i>{{item.system.damage}}</a><span class="text-lowercase">{{#if item.system.hefty}},
        {{localize "MB.Item.Hefty"}}{{/if}}{{#if item.system.long}},
        {{localize "MB.Item.Long"}}{{/if}}{{#if item.system.slow}}, {{localize "MB.Item.Slow"}}{{/if}}
    </span>
  </p>
  {{{item.extra.enrichedDescription}}}
{{/inline}}