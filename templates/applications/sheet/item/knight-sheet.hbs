<section class="flexcol knight">
  <div class="paper scrollable br-1 p-2 gap-2">

    <div class="grid">
      <label class="col col-3 text-large label-large">{{localize "MB.Item.Name"}}</label>
      <div class="col col-9">
        <input class="br-1 input-large" name="name" type="text" value="{{document.name}}" placeholder="{{ localize 'MB.Item.Name' }}" spellcheck="false" />
      </div>
    </div>

    <div class="grid align-items-center">
      <label class="col col-3 text-regular">{{localize "MB.Item.Description"}}</label>
      <div class="col col-9">
        <input class="br-1 input-simple" name="system.description" type="text" value="{{document.system.description}}" placeholder="{{ localize 'MB.Item.Description' }}" spellcheck="false" />
      </div>
    </div>

    <div class="grid align-items-center">
      <label class="col col-3 text-regularr">{{localize "MB.Item.Flavor"}}</label>
      <div class="col col-9">
        <input class="br-1 input-simple" name="system.flavor" type="text" value="{{document.system.flavor}}" placeholder="{{ localize 'MB.Item.Flavor' }}" spellcheck="false" />
      </div>
    </div>

    <div class="grid align-items-center">
      <label class="col col-3 text-regular">{{localize "MB.Item.FlavorLabel1"}}</label>
      <div class="col col-9">
        <input class="br-1 input-simple" name="system.flavorLabel1" type="text" value="{{document.system.flavorLabel1}}" placeholder="{{ localize 'MB.Item.FlavorLabel1' }}" spellcheck="false" />
      </div>
    </div>

    <div class="grid align-items-center">
      <label class="col col-3 text-regular">{{localize "MB.Item.FlavorLabel2"}}</label>
      <div class="col col-9">
        <input class="br-1 input-simple" name="system.flavorLabel2" type="text" value="{{document.system.flavorLabel2}}" placeholder="{{ localize 'MB.Item.FlavorLabel2' }}" spellcheck="false" />
      </div>
    </div>
  </div>
</section>