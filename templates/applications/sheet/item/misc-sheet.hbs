<section class="flexcol misc">
  <div class="paper scrollable br-1 p-2 gap-2">

    <div class="grid">
      <label class="col col-3 text-large label-large">{{localize "MB.Item.Name"}}</label>
      <div class="col col-9">
        <input class="br-1 input-large" name="name" type="text" value="{{document.name}}" placeholder="{{ localize 'MB.Item.Name' }}" spellcheck="false" />
      </div>
    </div>

    <div class="grid">
      <label class="col col-3 text-regular label-number">{{localize "MB.Item.Quantity"}}</label>
      <div class="col col-1">
        <input class="input-number" type="number" name="system.quantity.value" value="{{document.system.quantity.value}}" data-dtype="Number" />
      </div>
      <div class="col col-1">
        <span class="text-number text-align-center">/</span>
      </div>
      <div class="col col-1">
        <input class="input-number" type="number" name="system.quantity.max" value="{{document.system.quantity.max}}" data-dtype="Number" />
      </div>
    </div>

    <div class="grid">
      <h2 class="col col-12 text-large">{{localize "MB.Item.Description"}}</h2>
      <div class="col col-12 editor-container">
        {{#if editable}}
          <prose-mirror name="system.description" value="{{document.system.description}}" document-uuid="{{item.uuid}}" toggled="true" editable="{{editable}}">{{{extra.enrichedDescription}}}</prose-mirror>
        {{else}}
          <div class="editor">
            <div class="editor-content">{{{ extra.enrichedDescription }}}</div>
          </div>
        {{/if}}
      </div>
    </div>

  </div>
</section>